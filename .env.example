# Database
DATABASE_URL=mysql://flowforge:flowforge_pass@localhost:3306/flowforge
MYSQL_ROOT_PASSWORD=flowforge_root
MYSQL_DATABASE=flowforge
MYSQL_USER=flowforge
MYSQL_PASSWORD=flowforge_pass
MYSQL_PORT=3306

# Redis
REDIS_URL=redis://localhost:6379
REDIS_PORT=6379

# Security
JWT_SECRET=your-secret-key-change-in-production
CREDENTIAL_MASTER_KEY=your-master-key-change-in-production

# Manus OAuth
VITE_APP_ID=your-manus-app-id
VITE_APP_TITLE=FlowForge
OAUTH_SERVER_URL=https://api.manus.im
VITE_OAUTH_PORTAL_URL=https://portal.manus.im

# Manus APIs
BUILT_IN_FORGE_API_URL=https://api.manus.im
BUILT_IN_FORGE_API_KEY=your-api-key
VITE_FRONTEND_FORGE_API_URL=https://api.manus.im
VITE_FRONTEND_FORGE_API_KEY=your-frontend-api-key

# Application
NODE_ENV=development
APP_PORT=3000

# SMTP (for email node)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@flowforge.dev

# Scheduler
SCHEDULER_ENABLED=true
